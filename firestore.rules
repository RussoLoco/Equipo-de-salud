rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isSuper() { 
      return isSignedIn() && request.auth.token.email == 'davidhhgg620@gmail.com'; 
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasAnyRole(roles) {
      return isSignedIn() && (
        isSuper() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role in roles)
      );
    }
    
    function isAdmin() { return hasAnyRole(['admin']); }
    function isPharmacy() { return hasAnyRole(['admin', 'pharmacy']); }
    function isDoctor() { return hasAnyRole(['admin', 'doctor']); }
    function isAdmission() { return hasAnyRole(['admin', 'admission']); }
    function isNurse() { return hasAnyRole(['admin', 'nurse']); }
    function isNutritionist() { return hasAnyRole(['admin', 'nutritionist']); }
    function isSpecialist() { return hasAnyRole(['admin', 'ecografista', 'psiquiatra', 'odontologo']); }
    function isStaff() {
      return hasAnyRole(['admin', 'doctor', 'nurse', 'admission', 'nutritionist', 'ecografista', 'psiquiatra', 'odontologo']);
    }
    function isRestrictedSpecialist() {
      return isSignedIn() && !isSuper() && (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role in ['ecografista', 'psiquiatra', 'odontologo']);
    }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_ .+()#:-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidPatient(data) {
      return data.keys().hasAll(['id', 'dni', 'name', 'createdAt'])
        && data.id is string
        && data.dni is string
        && data.name is string;
    }

    function isValidVisit(data) {
      return (data.status == null || data.status in ['checkin', 'espera', 'atendiendo', 'atendiendo_nutri', 'atendiendo_especialista', 'atendido', 'anulado'])
        && (data.patientId == null || data.patientId is string)
        && (data.serviceType == null || data.serviceType in ['pediatría', 'clínico', 'ecografía', 'psiquiatra', 'psiquiatría', 'odontología', 'odontólogo', 'odontologo', 'nutricionista', 'nutrición', 'farmacia', 'laboratorio']);
    }

    function isValidMedicine(data) {
      return data.keys().hasAll(['drugId', 'drug', 'category', 'location', 'stock'])
        && data.drugId is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'date', 'doctorId', 'doctorName', 'items', 'status'])
        && data.orderId is string;
    }

    function isValidUser(data) {
      return data.name is string;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuper());
      allow list: if isSuper() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin');
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && isValidUser(incoming()))
      );
    }

    match /inventory/{drugId} {
      allow read: if isSignedIn();
      allow create: if !isRestrictedSpecialist() && (isPharmacy() || isAdmin()) && isValidId(drugId) && isValidMedicine(incoming());
      allow update: if !isRestrictedSpecialist() && (isPharmacy() || isAdmin()) && isValidMedicine(incoming());
      allow delete: if !isRestrictedSpecialist() && (isPharmacy() || isDoctor() || isAdmin());
    }

    match /orders/{orderId} {
      allow get: if isDoctor() || isSpecialist() || isPharmacy() || isAdmin() || isSuper();
      allow list: if isDoctor() || isSpecialist() || isPharmacy() || isAdmin() || isSuper();
      allow create: if isSuper() || isAdmin() || (
        (isDoctor() || isSpecialist()) && isValidOrder(incoming()) && (incoming().status == 'Pendiente' || incoming().status == 'En_Interconsulta')
      );
      allow update: if isSuper() || isAdmin() || (
          (isPharmacy() && incoming().status == 'Entregado' && (existing().status == 'Pendiente' || existing().status == 'En_Interconsulta'))
          || ((isDoctor() || isSpecialist()) && (existing().status == 'Pendiente' || existing().status == 'En_Interconsulta') && isValidOrder(incoming()))
        );
      allow delete: if isAdmin() || isSuper();
    }
    
    match /uploads_history/{uploadId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    match /doctors/{doctorId} {
      allow read: if isSignedIn();
      allow write: if isPharmacy();
    }

    match /patients/{patientId} {
      allow read: if isSignedIn() && isStaff();
      allow create: if (isAdmission() || isAdmin()) && isValidPatient(incoming());
      allow update: if (isAdmission() || isDoctor() || isSpecialist() || isAdmin());
      allow delete: if isAdmin();
      
      match /visits/{visitId} {
        allow read: if isSignedIn() && isStaff();
        allow create: if isSuper() || (isStaff() && isValidVisit(incoming()));
        allow update: if isSuper() || (isStaff() && isValidVisit(incoming()));
        allow delete: if isAdmin();
      }

      match /files/{fileId} {
        allow read: if isSignedIn() && isStaff();
        allow create: if isSignedIn() && (isDoctor() || isSpecialist() || isNutritionist() || isAdmin());
        allow delete: if isAdmin();
      }
    }

    match /visits/{visitId} {
      allow read: if isSignedIn() && isStaff();
      allow create: if isSuper() || (isStaff() && isValidVisit(incoming()));
      allow update: if isSuper() || (isStaff() && isValidVisit(incoming()));
      allow delete: if isAdmin();
    }
  }
}
