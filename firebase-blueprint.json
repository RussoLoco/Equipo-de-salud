{
  "entities": {
    "Medicine": {
      "title": "Medicine",
      "description": "Information about a medicine in the inventory.",
      "type": "object",
      "properties": {
        "drugId": { "type": "string" },
        "drug": { "type": "string" },
        "brandName": { "type": "string" },
        "presentation": { "type": "string" },
        "therapeuticAction": { "type": "string" },
        "dosage": { "type": "string" },
        "stock": { "type": "string" },
        "expirationDate": { "type": "string" },
        "laboratory": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string", "enum": ["Niño", "Adulto"] },
        "uploadId": { "type": "string" }
      },
      "required": ["drugId", "drug", "category", "presentation", "laboratory", "location", "stock"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Authorized doctor information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["id", "name", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "A medicine order made by a doctor.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "patientDni": { "type": "string" },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "drugId": { "type": "string" },
              "drugName": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["Pendiente", "Entregado"] },
        "location": { "type": "string" },
        "deliveredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "date", "doctorId", "doctorName", "items", "status", "location"]
    },
    "User": {
      "title": "User",
      "description": "App user roles and profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["doctor", "pharmacy", "admission", "nurse", "nutritionist", "ecografista", "psiquiatra", "odontologo", "admin"] },
        "name": { "type": "string" },
        "lastName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "isPending": { "type": "boolean" },
        "profileCompleted": { "type": "boolean" }
      },
      "required": ["uid", "role", "name", "email"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient basic profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dni": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "age": { "type": "string" },
        "category": { "type": "string", "enum": ["Adulto", "Niño"] },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "clinicalHistory": { "type": "string" },
        "guardianName": { "type": "string" },
        "guardianRelation": { "type": "string", "enum": ["Madre", "Padre", "Familiar"] }
      },
      "required": ["id", "dni", "name", "createdAt"]
    },
    "Visit": {
      "title": "Visit",
      "description": "A specific medical visit/encounter.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "patientDni": { "type": "string" },
        "category": { "type": "string", "enum": ["Adulto", "Niño"] },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["checkin", "espera", "atendiendo", "atendido"] },
        "attendingDoctorId": { "type": "string" },
        "attendingDoctorName": { "type": "string" },
        "vitals": {
          "type": "object",
          "properties": {
            "date": { "type": "string" },
            "weight": { "type": "string" },
            "height": { "type": "string" },
            "temperature": { "type": "string" },
            "bloodPressure": { "type": "string" },
            "recordedBy": { "type": "string" }
          }
        },
        "evolution": {
          "type": "object",
          "properties": {
            "date": { "type": "string" },
            "antecedents": { "type": "string" },
            "notes": { "type": "string" },
            "doctorName": { "type": "string" },
            "doctorId": { "type": "string" }
          }
        },
        "orderIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "patientId", "date", "status", "vitals"]
    },
    "UploadRecord": {
      "title": "UploadRecord",
      "description": "History of CSV uploads.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "filename": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "itemCount": { "type": "number" }
      },
      "required": ["id", "filename", "timestamp", "itemCount"]
    }
  },
  "firestore": {
    "/inventory/{drugId}": {
      "schema": "Medicine",
      "description": "Store medicines and their stock levels."
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "List of authorized doctors names for the dropdown (legacy/reference)."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Patient orders for medicines."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Roles and identifying info for users."
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient profiles."
    },
    "/patients/{patientId}/visits/{visitId}": {
      "schema": "Visit",
      "description": "Visit history for a patient."
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Flat list index for active visits (status logic)."
    },
    "/uploads_history/{uploadId}": {
      "schema": "UploadRecord",
      "description": "Log of bulk upload operations."
    }
  }
}
